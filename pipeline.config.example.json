{
  "splitterCommand": "go run ./cmd/uncluster-split -input \"{input}\" -output \"{split_output}\"",
  "ejsCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./scripts/codex-refactor-file.ps1\" -InputPath \"{input}\" -OutputPath \"{output}\" -PromptPath \"{prompt}\" -Target \"ejs\"",
  "reactCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File \"./scripts/codex-refactor-file.ps1\" -InputPath \"{input}\" -OutputPath \"{output}\" -PromptPath \"{prompt}\" -Target \"{target}\"",
  "defaultReactTarget": "tsx",
  "paths": {
    "runRoot": ".runs",
    "splitOutput": "split",
    "ejsOutput": "ejs",
    "reactOutput": "react"
  },
  "prompts": {
    "ejs": "prompts/ejs-refactor.prompt.md",
    "react": "prompts/react-refactor.prompt.md"
  },
  "riskPatterns": [
    "webflow",
    "__wf",
    "framer",
    "gsap",
    "barba",
    "locomotive",
    "lenis",
    "swiper",
    "anime(\\.min)?\\.js",
    "three(\\.min)?\\.js",
    "jquery\\.[a-z0-9\\-_]+(\\.min)?\\.js"
  ]
}
